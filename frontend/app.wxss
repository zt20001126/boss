/**app.wxss**/
page {
  --color-bg: #f4f6fb;
  --color-surface: #ffffff;
  --color-text: #162033;
  --color-muted: #667085;
  --color-border: #e1e7f0;
  --color-primary: #5b6ff5;
  --color-primary-pressed: #4457d8;
  --color-primary-soft: #eef1ff;
  --color-accent: #20b6d2;
  --color-success: #14795b;
  --color-success-soft: #eaf8f3;
  --color-danger: #b42318;
  --color-danger-soft: #fff1f0;
  --color-warning-soft: #fff7e6;
  --radius-sm: 12rpx;
  --radius-md: 18rpx;
  --shadow-sm: 0 10rpx 24rpx rgba(35, 48, 88, 0.07);
  --shadow-md: 0 18rpx 42rpx rgba(35, 48, 88, 0.11);
  --shadow-inner: inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
  --space-page: 32rpx;
  --space-section: 28rpx;
  background: #f4f6fb;
  color: #162033;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 20% 0%, rgba(91, 111, 245, 0.12) 0, rgba(91, 111, 245, 0) 280rpx),
    linear-gradient(180deg, #f7f8ff 0, #f4f6fb 360rpx, #f4f6fb 100%);
  overflow-x: hidden;
}

.section {
  margin-bottom: 28rpx;
}

.card {
  background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
  border: 1rpx solid rgba(218, 225, 238, 0.96);
  border-radius: 18rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
}

.card-pressed {
  transform: scale(0.985);
  box-shadow: 0 8rpx 18rpx rgba(35, 48, 88, 0.08);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-width: 0;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #111827;
}

.subtitle {
  margin-top: 10rpx;
  color: #5f6f85;
  font-size: 26rpx;
  line-height: 1.6;
  word-break: break-word;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  max-width: 220rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(32, 182, 210, 0.12), rgba(91, 111, 245, 0.12));
  color: #4254ce;
  font-size: 22rpx;
  line-height: 1.3;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: none;
}

.muted {
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
  word-break: break-word;
}

.primary-btn,
.ghost-btn,
.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  height: auto;
  line-height: 1.35;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 18rpx 24rpx;
  border: 0;
  box-sizing: border-box;
  white-space: normal;
  word-break: keep-all;
  box-shadow: none;
}

.primary-btn::after,
.ghost-btn::after,
.danger-btn::after {
  border: 0;
}

.primary-btn {
  background: linear-gradient(135deg, #5b6ff5, #20b6d2);
  color: #ffffff;
  box-shadow: 0 14rpx 28rpx rgba(91, 111, 245, 0.24);
}

.ghost-btn {
  color: #5062df;
  background: #eef1ff;
}

.danger-btn {
  color: #b42318;
  background: #fff1f0;
}

.field {
  margin-bottom: 22rpx;
  min-width: 0;
}

form {
  display: block;
  padding: 28rpx 28rpx 40rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(213, 221, 233, 0.9);
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(25, 39, 70, 0.05);
  box-sizing: border-box;
}

.label {
  display: block;
  color: #344054;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #d6deeb;
  border-radius: 14rpx;
  background: #fbfcff;
  color: #162033;
  font-size: 28rpx;
  box-shadow: var(--shadow-inner);
}

.input {
  display: block;
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  overflow: visible;
}

.textarea {
  display: block;
  min-height: 190rpx;
  line-height: 1.55;
  padding: 22rpx 24rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  min-width: 0;
}

.empty {
  padding: 56rpx 24rpx;
  text-align: center;
  color: #667085;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  margin-bottom: 18rpx;
  color: #111827;
}

.card-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-word;
  min-width: 0;
}

.status-success {
  color: #14795b;
  background: #eaf8f3;
}

.status-danger {
  color: #b42318;
  background: #fff1f0;
}

@media screen and (max-width: 360px) {
  .page {
    padding: 24rpx;
  }

  .card {
    padding: 24rpx;
  }

  .grid {
    grid-template-columns: 1fr;
  }

  .row {
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .primary-btn,
  .ghost-btn,
  .danger-btn {
    min-height: 80rpx;
    padding: 18rpx 20rpx;
    font-size: 26rpx;
  }

  .title {
    font-size: 38rpx;
  }

  .tag {
    max-width: 180rpx;
  }
}
