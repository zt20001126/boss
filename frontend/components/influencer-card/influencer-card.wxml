<view class="card influencer-card" hover-class="card-pressed">
  <view class="card-head">
    <image wx:if="{{item.avatarUrl}}" class="talent-avatar image-avatar" src="{{item.avatarUrl}}" mode="aspectFill" />
    <view wx:else class="talent-avatar">达</view>
    <view class="head-main">
      <view class="card-title">{{item.nickname}}</view>
      <view class="meta">{{item.city ? item.city + ' · ' : ''}}{{item.platform}} · {{item.fansRange}}</view>
    </view>
    <text class="tag">{{item.categories || item.category}}</text>
  </view>
  <view class="info-grid">
    <view class="info-pill">图文 {{item.priceImageText || item.priceRange}}</view>
    <view class="info-pill">视频 {{item.priceVideo || item.priceRange}}</view>
    <view class="info-pill" wx:if="{{item.contentForms}}">{{item.contentForms}}</view>
    <view class="info-pill">{{item.unlocked ? '已解锁' : '待解锁'}}</view>
  </view>
  <view class="contact-line">联系方式：{{item.contact}}</view>
  <view class="meta" wx:if="{{item.unlocked}}">社交账号：{{item.socialAccount}}</view>
  <button wx:if="{{!item.unlocked}}" class="primary-btn unlock" hover-class="card-pressed" catchtap="onUnlock">解锁联系方式</button>
  <button wx:else class="ghost-btn unlock" disabled>已解锁</button>
</view>
