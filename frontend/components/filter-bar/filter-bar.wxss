.filter-bar {
  margin-bottom: 24rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(218, 225, 238, 0.96);
  box-shadow: 0 12rpx 30rpx rgba(35, 48, 88, 0.08);
  box-sizing: border-box;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-track {
  display: inline-flex;
  gap: 14rpx;
  min-width: 100%;
  padding-bottom: 2rpx;
}

.filter-chip {
  width: 220rpx;
  min-height: 102rpx;
  padding: 14rpx 16rpx 12rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 1rpx solid #dce3ef;
  box-shadow: 0 8rpx 18rpx rgba(35, 48, 88, 0.05);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.filter-chip-wide {
  width: 260rpx;
}

.chip-label {
  display: block;
  color: #5062df;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.25;
}

.chip-input {
  width: 100%;
  min-width: 0;
  height: 44rpx;
  min-height: 44rpx;
  padding: 0;
  color: #162033;
  font-size: 26rpx;
  line-height: 44rpx;
}

.filter-action {
  width: 100%;
  min-height: 76rpx;
  margin-top: 16rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #5b6ff5, #20b6d2);
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.3;
  box-shadow: 0 14rpx 28rpx rgba(91, 111, 245, 0.2);
}

.filter-action::after {
  border: 0;
}

.filter-action-pressed {
  transform: scale(0.985);
  box-shadow: 0 8rpx 18rpx rgba(91, 111, 245, 0.18);
}
