.filter-bar {
  margin-bottom: 24rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(218, 225, 238, 0.96);
  box-shadow: 0 14rpx 34rpx rgba(35, 48, 88, 0.08);
  box-sizing: border-box;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-track {
  display: inline-flex;
  gap: 14rpx;
  min-width: 100%;
  padding-bottom: 2rpx;
}

.filter-chip {
  width: 214rpx;
  min-height: 72rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff, #f7f9ff);
  border: 1rpx solid #e1e7f0;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.95), 0 8rpx 18rpx rgba(35, 48, 88, 0.05);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.filter-chip-wide {
  width: 250rpx;
}

.chip-label {
  flex: none;
  color: #5062df;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
}

.chip-input {
  flex: 1;
  min-width: 0;
  height: 42rpx;
  min-height: 42rpx;
  padding: 0;
  color: #162033;
  font-size: 23rpx;
  line-height: 42rpx;
}

.filter-action {
  width: 100%;
  min-height: 76rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5b6ff5, #20b6d2);
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.3;
  box-shadow: 0 14rpx 28rpx rgba(91, 111, 245, 0.2);
}

.filter-action::after {
  border: 0;
}

.filter-action-pressed {
  transform: scale(0.985);
  box-shadow: 0 8rpx 18rpx rgba(91, 111, 245, 0.18);
}
