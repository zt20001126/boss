.empty-state {
  padding: 72rpx 24rpx;
  text-align: center;
  color: #667085;
  background: linear-gradient(180deg, #ffffff, #fbfcff);
  border: 1rpx dashed #cfd8ea;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 30rpx rgba(35, 48, 88, 0.06);
  box-sizing: border-box;
}

.empty-mark {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 18rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(91, 111, 245, 0.18), rgba(32, 182, 210, 0.18));
  border: 1rpx solid #d8defb;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.empty-text {
  font-size: 24rpx;
  line-height: 1.5;
}
