.product-card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
  box-shadow: 0 16rpx 38rpx rgba(35, 48, 88, 0.09);
}

.card-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.brand-avatar {
  width: 72rpx;
  height: 72rpx;
  flex: none;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #5b6ff5, #20b6d2);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 26rpx rgba(91, 111, 245, 0.22);
}

.head-main {
  flex: 1;
  min-width: 0;
}

.card-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 850;
  line-height: 1.35;
  word-break: break-word;
}

.meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
  word-break: break-word;
}

.product-card .subtitle {
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-top: 18rpx;
  color: #506070;
  font-size: 25rpx;
  line-height: 1.6;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.info-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f2f5ff;
  color: #5062df;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
}

.offline-tag {
  background: #fff1f0;
  color: #b42318;
}

.actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.action-btn {
  min-height: 70rpx;
  font-size: 24rpx;
  padding: 12rpx 8rpx;
}

@media screen and (max-width: 360px) {
  .actions {
    grid-template-columns: 1fr;
  }
}
