.login-page {
  height: calc(100vh - 48px - env(safe-area-inset-top));
  min-height: 0;
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff8ec 0%, #fffdf8 46%, #ffffff 100%);
  color: #171717;
  overflow: hidden;
}

.login-shell,
.bind-shell {
  height: 100%;
  min-height: 0;
  box-sizing: border-box;
  padding: 32rpx 48rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.brand-ad {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: none;
}

.ad-line {
  display: block;
  color: rgba(84, 79, 72, 0.66);
  font-size: 25rpx;
  line-height: 1.45;
  font-weight: 400;
  letter-spacing: 0;
}

.brand-core {
  flex: 1;
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0 28rpx;
}

.brand-mark {
  color: #15120d;
  font-size: 74rpx;
  line-height: 1.05;
  font-weight: 900;
  letter-spacing: 0;
  text-align: center;
}

.brand-slogan {
  margin-top: 14rpx;
  color: rgba(42, 38, 32, 0.46);
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 600;
  letter-spacing: 0;
  text-align: center;
}

.login-action {
  width: 100%;
  flex: none;
}

.wechat-login-btn {
  width: 100%;
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 16rpx;
  background: #07c160;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
  box-shadow: 0 14rpx 28rpx rgba(7, 193, 96, 0.22);
}

.wechat-login-btn::after,
.role-card::after {
  border: 0;
}

.wechat-login-btn[disabled] {
  background: rgba(7, 193, 96, 0.62);
  color: rgba(255, 255, 255, 0.9);
}

.bind-shell {
  align-items: center;
  justify-content: center;
  gap: 34rpx;
}

.bind-copy {
  text-align: center;
}

.bind-title {
  color: #15120d;
  font-size: 46rpx;
  line-height: 1.2;
  font-weight: 800;
}

.bind-subtitle {
  margin-top: 14rpx;
  color: rgba(84, 79, 72, 0.64);
  font-size: 26rpx;
  line-height: 1.55;
}

.role-grid {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.role-card {
  width: 100%;
  max-width: 560rpx;
  min-height: 132rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(30, 24, 16, 0.08);
  box-shadow: 0 12rpx 28rpx rgba(40, 35, 28, 0.07);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.role-card-active {
  border-color: rgba(7, 193, 96, 0.8);
  background: rgba(240, 255, 247, 0.94);
}

.role-title {
  color: #15120d;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
}

.role-desc {
  color: rgba(84, 79, 72, 0.58);
  font-size: 23rpx;
  line-height: 1.4;
}

@media screen and (max-width: 360px) {
  .login-shell,
  .bind-shell {
    padding: 24rpx 34rpx calc(20rpx + env(safe-area-inset-bottom));
  }

  .brand-core {
    min-height: 150rpx;
    padding: 14rpx 0 20rpx;
  }

  .brand-mark {
    font-size: 62rpx;
  }

  .ad-line {
    font-size: 23rpx;
    line-height: 1.38;
  }

  .wechat-login-btn {
    min-height: 84rpx;
    font-size: 29rpx;
  }

  .role-card {
    max-width: 100%;
    min-height: 120rpx;
  }
}
