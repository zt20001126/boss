.login-page {
  min-height: calc(100vh - 48px - env(safe-area-inset-top));
  box-sizing: border-box;
  background: linear-gradient(180deg, #fff8ec 0%, #fffdf8 42%, #ffffff 100%);
  color: #171717;
}

.login-shell,
.bind-shell {
  min-height: calc(100vh - 48px - env(safe-area-inset-top));
  box-sizing: border-box;
  padding: 56rpx 48rpx calc(36rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.brand-ad {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: none;
}

.ad-line {
  display: block;
  color: rgba(84, 79, 72, 0.62);
  font-size: 26rpx;
  line-height: 1.55;
  font-weight: 400;
  letter-spacing: 0;
}

.brand-core {
  flex: 1;
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.brand-mark {
  color: #15120d;
  font-size: 80rpx;
  line-height: 1.1;
  font-weight: 900;
  letter-spacing: 0;
  text-align: center;
}

.brand-slogan {
  margin-top: 18rpx;
  color: rgba(42, 38, 32, 0.44);
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 600;
  letter-spacing: 0;
  text-align: center;
}

.login-action {
  width: 100%;
  flex: none;
}

.wechat-login-btn {
  width: 100%;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 999rpx;
  background: #07c160;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
  box-shadow: 0 18rpx 36rpx rgba(7, 193, 96, 0.24);
}

.wechat-login-btn::after,
.role-card::after {
  border: 0;
}

.wechat-login-btn[disabled] {
  background: rgba(7, 193, 96, 0.62);
  color: rgba(255, 255, 255, 0.9);
}

.bind-shell {
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.bind-copy {
  text-align: center;
}

.bind-title {
  color: #15120d;
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 800;
}

.bind-subtitle {
  margin-top: 16rpx;
  color: rgba(84, 79, 72, 0.64);
  font-size: 26rpx;
  line-height: 1.6;
}

.role-grid {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.role-card {
  width: 100%;
  max-width: 560rpx;
  min-height: 150rpx;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(30, 24, 16, 0.08);
  box-shadow: 0 14rpx 34rpx rgba(40, 35, 28, 0.07);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.role-card-active {
  border-color: rgba(7, 193, 96, 0.8);
  background: rgba(240, 255, 247, 0.94);
}

.role-title {
  color: #15120d;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
}

.role-desc {
  color: rgba(84, 79, 72, 0.58);
  font-size: 23rpx;
  line-height: 1.4;
}

@media screen and (max-width: 360px) {
  .login-shell,
  .bind-shell {
    padding: 36rpx 36rpx calc(28rpx + env(safe-area-inset-bottom));
  }

  .brand-core {
    min-height: 240rpx;
    padding: 28rpx 0;
  }

  .brand-mark {
    font-size: 68rpx;
  }

  .ad-line {
    font-size: 24rpx;
    line-height: 1.45;
  }

  .wechat-login-btn {
    min-height: 88rpx;
    font-size: 29rpx;
  }

  .role-card {
    max-width: 100%;
    min-height: 132rpx;
  }
}
