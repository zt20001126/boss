.workspace-page {
  height: 100vh;
  background:
    radial-gradient(circle at 15% 0%, rgba(91, 111, 245, 0.12) 0, rgba(91, 111, 245, 0) 310rpx),
    linear-gradient(180deg, #f8f9ff 0, #f4f6fb 100%);
  overflow: hidden;
}

.workspace-scroll {
  height: calc(100vh - 128rpx - env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.tab-panel {
  min-height: 100%;
  padding: 28rpx 32rpx 36rpx;
  box-sizing: border-box;
}

.mine-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(218, 225, 238, 0.96);
  border-radius: 20rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
  box-shadow: 0 16rpx 38rpx rgba(35, 48, 88, 0.09);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.mine-title {
  color: #111827;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
}

.mine-desc {
  margin-top: 14rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.55;
  word-break: break-word;
}

.mine-arrow {
  color: #7c8aff;
  font-size: 46rpx;
  line-height: 1;
}

.bottom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  gap: 18rpx;
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.88);
  border-top: 1rpx solid #e4e9f2;
  box-shadow: 0 -14rpx 36rpx rgba(35, 48, 88, 0.12);
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  min-height: 72rpx;
  border-radius: 14rpx;
  background: #f2f4f9;
  color: #667085;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.35;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.tab-item-active {
  background: linear-gradient(135deg, #5b6ff5, #20b6d2);
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(91, 111, 245, 0.22);
}

.tab-icon {
  font-size: 22rpx;
  line-height: 1;
}

.tab-pressed {
  transform: scale(0.98);
}

.tab-item::after {
  border: 0;
}
