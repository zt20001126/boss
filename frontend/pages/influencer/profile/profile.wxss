.profile-page {
  min-height: 100vh;
  padding: 30rpx 30rpx 0;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 0%, rgba(32, 182, 210, 0.11) 0, rgba(32, 182, 210, 0) 300rpx),
    linear-gradient(180deg, #f7f9fc 0, #f4f6fb 100%);
}

.profile-head {
  margin-bottom: 22rpx;
}

.visibility-card,
.form-section {
  background: #ffffff;
  border: 1rpx solid rgba(218, 225, 238, 0.96);
  border-radius: 16rpx;
  box-shadow: 0 12rpx 30rpx rgba(35, 48, 88, 0.07);
  box-sizing: border-box;
}

.visibility-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  padding: 26rpx;
  margin-bottom: 22rpx;
}

.visibility-copy {
  flex: 1;
  min-width: 0;
}

.profile-form {
  display: block;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.form-section {
  margin-bottom: 22rpx;
  padding: 26rpx;
}

.section-title {
  margin-bottom: 22rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.portfolio-title {
  margin-bottom: 8rpx;
}

.section-hint {
  margin-top: -8rpx;
  margin-bottom: 18rpx;
  color: #7d889a;
  font-size: 24rpx;
  line-height: 1.5;
}

.field {
  margin-bottom: 22rpx;
  min-width: 0;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #344054;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #d6deeb;
  border-radius: 12rpx;
  background: #fbfcff;
  color: #162033;
  font-size: 28rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.input {
  display: block;
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 22rpx;
}

.textarea {
  display: block;
  min-height: 176rpx;
  line-height: 1.55;
  padding: 20rpx 22rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.portfolio-item {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1f7;
}

.portfolio-head,
.portfolio-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.portfolio-head {
  margin-bottom: 4rpx;
}

.portfolio-row {
  min-height: 56rpx;
}

.portfolio-index {
  color: #344054;
  font-size: 25rpx;
  font-weight: 700;
}

.small-btn,
.remove-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: auto;
  min-width: 112rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  line-height: 56rpx;
}

.small-btn {
  border: 1rpx solid #1677ff;
  background: #eef6ff;
  color: #1677ff;
}

.remove-btn {
  border: 1rpx solid #f4c7c7;
  background: #fff5f5;
  color: #d92d20;
}

.save-btn {
  position: sticky;
  bottom: 0;
  z-index: 4;
  margin-top: 8rpx;
  margin-bottom: 0;
  border-radius: 14rpx 14rpx 0 0;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
}

@media screen and (max-width: 360px) {
  .profile-page {
    padding: 24rpx 24rpx 0;
  }

  .visibility-card,
  .form-section {
    padding: 24rpx;
  }

  .grid {
    grid-template-columns: 1fr;
    gap: 0;
  }
}
