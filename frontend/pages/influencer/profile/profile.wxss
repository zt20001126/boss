.profile-page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 0%, rgba(91, 111, 245, 0.12) 0, rgba(91, 111, 245, 0) 300rpx),
    linear-gradient(180deg, #f8f9ff 0, #f4f6fb 100%);
}

.profile-head {
  margin-bottom: 24rpx;
}

.visibility-card,
.form-section {
  background: linear-gradient(180deg, #ffffff 0%, #fbfcff 100%);
  border: 1rpx solid rgba(218, 225, 238, 0.96);
  border-radius: 18rpx;
  box-shadow: 0 12rpx 32rpx rgba(35, 48, 88, 0.07);
  box-sizing: border-box;
}

.visibility-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
}

.profile-form {
  display: block;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.form-section {
  margin-bottom: 22rpx;
  padding: 28rpx;
}

.section-title {
  margin-bottom: 22rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.section-hint {
  margin-top: -10rpx;
  margin-bottom: 20rpx;
  color: #8a94a6;
  font-size: 24rpx;
  line-height: 1.5;
}

.field {
  margin-bottom: 22rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  color: #344054;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #d6deeb;
  border-radius: 14rpx;
  background: #fbfcff;
  color: #162033;
  font-size: 28rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.input {
  display: block;
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
}

.textarea {
  display: block;
  min-height: 180rpx;
  line-height: 1.55;
  padding: 22rpx 24rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.portfolio-item {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.save-btn {
  margin-top: 8rpx;
  margin-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

@media screen and (max-width: 360px) {
  .profile-page {
    padding: 24rpx;
  }

  .visibility-card,
  .form-section {
    padding: 24rpx;
  }

  .grid {
    grid-template-columns: 1fr;
    gap: 0;
  }
}
