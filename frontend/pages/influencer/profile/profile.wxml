<navigation-bar title="达人资料" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<view class="profile-page">
  <view class="profile-head">
    <view class="title">完善达人资料</view>
    <view class="subtitle">先填写商家筛选和联系所需的核心信息，更多资料可以后续补充。</view>
  </view>

  <view class="visibility-card">
    <view class="visibility-copy">
      <view class="visibility-title">向商家展示我的资料</view>
      <view class="visibility-desc" wx:if="{{form.isPublic}}">商家可在达人库中看到你的公开资料，联系方式仍需解锁。</view>
      <view class="visibility-desc" wx:else>关闭后，你不会出现在商家的达人库和匹配结果中。</view>
    </view>
    <switch
      class="visibility-switch"
      checked="{{form.isPublic}}"
      disabled="{{visibilitySaving}}"
      color="#5b6ff5"
      bindchange="onVisibilityChange"
    />
  </view>

  <form bindsubmit="submit" class="profile-form">
    <view class="form-section">
      <view class="section-title">基础信息</view>
      <view class="field">
        <text class="label">达人昵称</text>
        <input class="input" name="nickname" value="{{form.nickname}}" placeholder="例如 小鹿探店" />
      </view>
      <view class="grid">
        <view class="field">
          <text class="label">所在城市</text>
          <input class="input" name="city" value="{{form.city}}" placeholder="例如 上海" />
        </view>
        <view class="field">
          <text class="label">主要平台</text>
          <input class="input" name="platform" value="{{form.platform}}" placeholder="小红书/抖音/视频号" />
        </view>
      </view>
    </view>

    <view class="form-section">
      <view class="section-title">合作信息</view>
      <view class="grid">
        <view class="field">
          <text class="label">粉丝数</text>
          <input class="input" type="number" name="fansCount" value="{{form.fansCount}}" placeholder="例如 10000" />
        </view>
        <view class="field">
          <text class="label">内容领域</text>
          <input class="input" name="category" value="{{form.category}}" placeholder="美妆/数码/本地生活" />
        </view>
      </view>
      <view class="field">
        <text class="label">报价</text>
        <input class="input" name="priceRange" value="{{form.priceRange}}" placeholder="例如 800-1500 元/条" />
      </view>
      <view class="field">
        <text class="label">联系方式</text>
        <input class="input" name="contact" value="{{form.contact}}" placeholder="微信/手机号/邮箱" />
      </view>
    </view>

    <view class="form-section">
      <view class="portfolio-head">
        <view>
          <view class="section-title portfolio-title">代表作品</view>
          <view class="section-hint">默认 1 条，可继续添加或删除。</view>
        </view>
        <button class="small-btn" type="default" bindtap="addPortfolio">添加</button>
      </view>

      <view class="portfolio-item" wx:for="{{portfolioList}}" wx:key="index">
        <view class="portfolio-row">
          <text class="portfolio-index">作品 {{index + 1}}</text>
          <button
            wx:if="{{portfolioList.length > 1}}"
            class="remove-btn"
            type="default"
            data-index="{{index}}"
            bindtap="removePortfolio"
          >删除</button>
        </view>
        <input
          class="input"
          value="{{item.title}}"
          placeholder="作品标题"
          data-index="{{index}}"
          data-field="title"
          bindinput="onPortfolioInput"
        />
        <textarea
          class="textarea"
          value="{{item.content}}"
          placeholder="作品内容，可填写链接、简介或关键数据"
          data-index="{{index}}"
          data-field="content"
          bindinput="onPortfolioInput"
        />
      </view>
    </view>

    <button class="primary-btn save-btn" form-type="submit" loading="{{saving}}" disabled="{{saving}}">
      {{saving ? '保存中' : '保存资料'}}
    </button>
  </form>
</view>
