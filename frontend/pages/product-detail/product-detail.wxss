.line {
  min-height: 66rpx;
  border-bottom: 1rpx solid #eef0f4;
  padding: 14rpx 0;
  box-sizing: border-box;
  align-items: flex-start;
}

.line:last-child {
  border-bottom: 0;
}

.section-title,
.card-title {
  color: #111827;
}

.section-title {
  margin-bottom: 18rpx;
}

.line text:last-child {
  flex: 1;
  min-width: 0;
  text-align: right;
  line-height: 1.55;
  word-break: break-word;
}

.detail-page-with-actions {
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.detail-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1.5fr);
  gap: 18rpx;
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e4e9f2;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -14rpx 36rpx rgba(35, 48, 88, 0.12);
  box-sizing: border-box;
}

.favorite-btn,
.contact-btn {
  min-height: 80rpx;
  margin: 0;
  border-radius: 14rpx;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.35;
  display: flex;
  align-items: center;
  justify-content: center;
}

.favorite-btn {
  border: 1rpx solid #cfd7ff;
  background: #eef1ff;
  color: #5062df;
}

.favorite-btn-active {
  border-color: #5b6ff5;
  background: #e8ecff;
  color: #3f51c9;
}

.contact-btn {
  border: 0;
  background: linear-gradient(135deg, #5b6ff5, #20b6d2);
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(91, 111, 245, 0.22);
}

.favorite-btn::after,
.contact-btn::after {
  border: 0;
}
