.workspace-page {
  height: 100vh;
  background:
    radial-gradient(circle at 15% 0%, rgba(32, 182, 210, 0.11) 0, rgba(32, 182, 210, 0) 310rpx),
    linear-gradient(180deg, #f8f9ff 0, #f4f6fb 100%);
  overflow: hidden;
}

.workspace-scroll {
  height: calc(100vh - 128rpx - env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.tab-panel {
  min-height: 100%;
  padding: 0 32rpx 36rpx;
  box-sizing: border-box;
}

.filter-bar-sticky {
  position: sticky;
  top: 0;
  z-index: 3;
  padding: 24rpx 0 18rpx;
  background: rgba(244, 246, 251, 0.96);
}

.filter-row {
  display: flex;
  gap: 14rpx;
}

.filter-control {
  flex: 1;
  min-width: 0;
  min-height: 102rpx;
  padding: 14rpx 16rpx 12rpx;
  border: 1rpx solid #dce3ef;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(35, 48, 88, 0.05);
  box-sizing: border-box;
}

.filter-label {
  display: block;
  color: #5062df;
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.filter-input {
  width: 100%;
  height: 44rpx;
  min-height: 44rpx;
  color: #111827;
  font-size: 26rpx;
  line-height: 44rpx;
  padding: 0;
}

.talent-card,
.mine-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(218, 225, 238, 0.96);
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(35, 48, 88, 0.08);
  box-sizing: border-box;
}

.talent-card {
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.talent-top,
.mine-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.talent-avatar {
  width: 72rpx;
  height: 72rpx;
  flex: none;
  border-radius: 50%;
  background: linear-gradient(135deg, #20b6d2, #5b6ff5);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 26rpx rgba(32, 182, 210, 0.2);
}

.image-avatar {
  display: block;
}

.talent-main {
  flex: 1;
  min-width: 0;
}

.talent-name,
.mine-title {
  flex: 1;
  min-width: 0;
  color: #111827;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
  word-break: break-word;
}

.talent-meta,
.mine-desc {
  margin-top: 14rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.55;
  word-break: break-word;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.info-pill {
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  background: #f2f5ff;
  color: #5062df;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.35;
}

.talent-foot {
  margin-top: 18rpx;
  color: #98a2b3;
  font-size: 23rpx;
  line-height: 1.4;
}

.mine-panel {
  padding-top: 28rpx;
}

.mine-arrow {
  color: #7c8aff;
  font-size: 46rpx;
  line-height: 1;
}

.profile-alert {
  border-color: #bfd7ff;
  background: #f6f9ff;
}

.bottom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  gap: 18rpx;
  padding: 18rpx 32rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.9);
  border-top: 1rpx solid #e4e9f2;
  box-shadow: 0 -14rpx 36rpx rgba(35, 48, 88, 0.12);
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  min-height: 72rpx;
  border-radius: 14rpx;
  background: #f2f4f9;
  color: #667085;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.35;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.tab-item-active {
  background: linear-gradient(135deg, #5b6ff5, #20b6d2);
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(91, 111, 245, 0.22);
}

.tab-icon {
  font-size: 18rpx;
  line-height: 1;
}

.tab-pressed {
  transform: scale(0.98);
}

.unlock-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(17, 24, 39, 0.42);
  animation: fade-in 180ms ease;
  box-sizing: border-box;
}

.unlock-modal {
  width: 100%;
  max-width: 620rpx;
  padding: 42rpx 34rpx 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 28rpx 70rpx rgba(15, 23, 42, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  text-align: center;
  animation: modal-in 180ms ease;
  box-sizing: border-box;
}

.unlock-icon {
  width: 86rpx;
  height: 86rpx;
  margin: 0 auto 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #5b6ff5, #20b6d2);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 900;
  box-shadow: 0 16rpx 32rpx rgba(91, 111, 245, 0.24);
}

.unlock-title {
  color: #111827;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 900;
}

.unlock-desc {
  margin-top: 16rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.6;
}

.unlock-target {
  display: inline-flex;
  max-width: 100%;
  margin-top: 20rpx;
  padding: 10rpx 18rpx;
  border-radius: 12rpx;
  background: #f2f5ff;
  color: #5062df;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.35;
  box-sizing: border-box;
}

.unlock-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 34rpx;
}

.unlock-cancel,
.unlock-confirm {
  min-height: 82rpx;
  border-radius: 14rpx;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.35;
}

.unlock-cancel {
  color: #667085;
  background: #f2f4f7;
}

.unlock-confirm {
  color: #ffffff;
  background: linear-gradient(135deg, #5b6ff5, #20b6d2);
  box-shadow: 0 14rpx 28rpx rgba(91, 111, 245, 0.22);
}

.unlock-cancel::after,
.unlock-confirm::after,
.tab-item::after {
  border: 0;
}

@keyframes fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes modal-in {
  from {
    opacity: 0;
    transform: scale(0.96) translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

@media screen and (max-width: 360px) {
  .filter-row {
    flex-direction: column;
  }
}
